<%- include('partials/header', { title: 'Cart' }) %>

    <main>
        <h2>Your Cart</h2>

        <% if (cart.length===0) { %>
            <p>Your cart is empty. Go back and add some items.</p>
            <% } else { %>
                <ul class="cart-list">
                    <% cart.forEach((item, index)=> { %>
                        <li>
                            <span><strong>
                                    <%= item.name %>
                                </strong> — $<%= item.price.toFixed(2) %></span>
                            <form action="/cart/remove" method="post" style="margin:0;">
                                <input type="hidden" name="index" value="<%= index %>" />
                                <button type="submit">Remove</button>
                            </form>
                        </li>
                        <% }) %>
                </ul>

                <div class="cart-summary">
                    <p><strong>Total:</strong> $<%= total.toFixed(2) %>
                    </p>
                </div>
                <% } %>

                    <div style="margin-top: 1rem;">
                        <a href="/">Continue Shopping</a>
                    </div>
    </main>

    <%- include('partials/footer') %>