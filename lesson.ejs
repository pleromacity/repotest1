<%- include('partials/header', { title: lesson.title }) %>

<div class="lesson-layout">
  <!-- Sidebar -->
  <aside class="lesson-sidebar">
    <a href="/courses/<%= course.slug %>" class="back-link">← <%= course.title %></a>
    <div class="sidebar-progress">
      <% const pct = Math.round((progress.completedLessons.length / course.lessonList.length) * 100); %>
      <span><%= pct %>% complete</span>
      <div class="progress-bar-wrap"><div class="progress-bar-fill" style="width: <%= pct %>%"></div></div>
    </div>
    <ul class="sidebar-lessons">
      <% course.lessonList.forEach((l, i) => { %>
        <li class="<%= l.id === lesson.id ? 'active' : '' %>">
          <a href="/courses/<%= course.slug %>/learn/<%= l.id %>">
            <span class="sbl-num"><%= progress.completedLessons.includes(l.id) ? '✓' : (i + 1) %></span>
            <span class="sbl-title"><%= l.title %></span>
            <span class="sbl-dur"><%= l.duration %></span>
          </a>
        </li>
      <% }) %>
    </ul>
  </aside>

  <!-- Main content -->
  <main class="lesson-main">
    <div class="lesson-header">
      <div class="lesson-breadcrumb">
        <span style="color: var(--accent, #4f46e5)"><%= course.icon %> <%= course.title %></span>
        <span>›</span>
        <span><%= lesson.title %></span>
      </div>
      <h1><%= lesson.title %></h1>
      <div class="lesson-meta"><span>⏱ <%= lesson.duration %></span></div>
    </div>

    <div class="lesson-content">
      <%- lesson.content %>
    </div>

    <!-- Quiz Section -->
    <% if (lesson.quiz) { %>
    <div class="quiz-section" id="quiz">
      <h3>🧠 Knowledge Check</h3>
      <p class="quiz-question"><%= lesson.quiz.question %></p>
      <div class="quiz-options" id="quizOptions">
        <% lesson.quiz.options.forEach((option, i) => { %>
          <button class="quiz-option" data-index="<%= i %>" onclick="selectOption(this, <%= i %>)">
            <span class="opt-letter"><%= ['A','B','C','D'][i] %></span>
            <%= option %>
          </button>
        <% }) %>
      </div>
      <div class="quiz-result hidden" id="quizResult"></div>
      <button class="btn btn-primary" id="submitQuiz" onclick="submitQuiz()" disabled>Submit Answer</button>
    </div>
    <% } %>

    <!-- Navigation -->
    <div class="lesson-nav">
      <% if (prevLesson) { %>
        <a href="/courses/<%= course.slug %>/learn/<%= prevLesson.id %>" class="btn btn-outline">← <%= prevLesson.title %></a>
      <% } else { %><div></div><% } %>
      <% if (nextLesson) { %>
        <a href="/courses/<%= course.slug %>/learn/<%= nextLesson.id %>" class="btn btn-primary" id="nextBtn">
          Next: <%= nextLesson.title %> →
        </a>
      <% } else { %>
        <a href="/dashboard" class="btn btn-primary">🏁 Finish Course</a>
      <% } %>
    </div>
  </main>
</div>

<script>
const courseSlug = '<%= course.slug %>';
const lessonId = '<%= lesson.id %>';
let selectedAnswer = null;

function selectOption(el, index) {
  document.querySelectorAll('.quiz-option').forEach(b => b.classList.remove('selected'));
  el.classList.add('selected');
  selectedAnswer = index;
  document.getElementById('submitQuiz').disabled = false;
}

async function submitQuiz() {
  if (selectedAnswer === null) return;
  const res = await fetch(`/courses/${courseSlug}/learn/${lessonId}/quiz`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ answer: selectedAnswer })
  });
  const data = await res.json();
  const result = document.getElementById('quizResult');
  result.classList.remove('hidden', 'correct', 'wrong');

  document.querySelectorAll('.quiz-option').forEach((btn, i) => {
    btn.disabled = true;
    if (i === data.correctAnswer) btn.classList.add('correct-answer');
    if (i === selectedAnswer && !data.correct) btn.classList.add('wrong-answer');
  });

  if (data.correct) {
    result.className = 'quiz-result correct';
    result.innerHTML = '🎉 Correct! Well done!';
  } else {
    const correctText = document.querySelectorAll('.quiz-option')[data.correctAnswer].textContent.trim();
    result.className = 'quiz-result wrong';
    result.innerHTML = `❌ Not quite. The correct answer is: <strong>${correctText}</strong>`;
  }
  document.getElementById('submitQuiz').disabled = true;

  // Mark lesson complete
  await fetch(`/courses/${courseSlug}/learn/${lessonId}/complete`, { method: 'POST' });
}

// Auto-mark lesson complete when scrolled to bottom
window.addEventListener('scroll', () => {
  const scrolled = (window.scrollY + window.innerHeight) / document.documentElement.scrollHeight;
  if (scrolled > 0.85) {
    fetch(`/courses/${courseSlug}/learn/${lessonId}/complete`, { method: 'POST' });
  }
});
</script>

<%- include('partials/footer') %>
