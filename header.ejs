<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ELearn' : 'ELearn' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <a href="/" class="nav-logo">E<span>Learn</span></a>
    <div class="nav-links">
      <a href="/courses">Courses</a>
      <% if (user) { %>
        <a href="/dashboard">Dashboard</a>
        <a href="/auth/logout" class="btn btn-outline">Logout</a>
      <% } else { %>
        <a href="/auth/login">Login</a>
        <a href="/auth/register" class="btn btn-primary">Sign Up Free</a>
      <% } %>
    </div>
  </nav>
