<%- include('partials/header', { title: 'Login' }) %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">E<span>Learn</span></div>
    <h2>Welcome back</h2>
    <p>Sign in to continue learning</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="demo-hint">
      💡 Demo: <code>demo@elearn.com</code> / <code>demo123</code>
    </div>

    <form method="POST" action="/auth/login" class="auth-form">
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" placeholder="you@example.com" required>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="••••••••" required>
      </div>
      <button type="submit" class="btn btn-primary btn-full">Sign In</button>
    </form>
    <p class="auth-switch">Don't have an account? <a href="/auth/register">Create one free →</a></p>
  </div>
</div>

<%- include('partials/footer') %>
